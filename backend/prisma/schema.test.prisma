// Test Prisma schema file for SQLite
// This is used for testing to avoid PostgreSQL dependency

generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/test-client"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  role      String   @default("USER")
  avatarUrl String?
  
  // Subscription and usage
  subscription    String @default("FREE")
  storageUsed     Int    @default(0)
  
  // Preferences
  preferences     String @default("{}")
  
  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  lastLoginAt DateTime?
  
  // Relations
  meetings            Meeting[]
  platformIntegrations PlatformIntegration[]
}

model Meeting {
  id          String   @id @default(cuid())
  title       String
  description String?
  userId      String
  
  // Meeting details
  platform     String
  meetingUrl   String?
  scheduledTime DateTime
  startTime    DateTime?
  endTime      DateTime?
  status       String @default("SCHEDULED")
  
  // File storage
  recordingUrl String?
  storageSize  Int     @default(0)
  
  // Participants (stored as JSON string)
  participants String  @default("[]")
  
  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  // Relations
  user        User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  transcripts TranscriptEntry[]
  summaries   Summary[]
}

model TranscriptEntry {
  id        String   @id @default(cuid())
  meetingId String
  
  // Transcript content
  speaker    String
  text       String
  timestamp  DateTime
  confidence Float
  isFinal    Boolean  @default(false)
  
  // Timestamps
  createdAt DateTime @default(now())
  
  // Relations
  meeting Meeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)
}

model Summary {
  id        String   @id @default(cuid())
  meetingId String
  
  // Summary content
  overallSummary String
  keyPoints      String @default("[]")
  actionItems    String @default("[]")
  nextSteps      String @default("[]")
  topics         String @default("[]")
  
  // Timestamps
  generatedAt DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  // Relations
  meeting Meeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)
}

model PlatformIntegration {
  id       String   @id @default(cuid())
  userId   String
  
  // Platform details
  platform     String
  accessToken  String
  refreshToken String?
  expiresAt    DateTime?
  status       String @default("CONNECTED")
  
  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}