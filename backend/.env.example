# Backend Environment Variables

# Server Configuration
PORT=5000
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# Database Configuration (MongoDB Atlas)
DATABASE_URL=mongodb+srv://username:password@cluster0.xxxxx.mongodb.net/meetbuddy_ai?retryWrites=true&w=majority
DATABASE_URL_TEST=mongodb+srv://username:password@cluster0.xxxxx.mongodb.net/meetbuddy_ai_test?retryWrites=true&w=majority

# Redis Configuration
REDIS_URL=redis://localhost:6379

# JWT Configuration
JWT_SECRET=your_super_secret_jwt_key_here
JWT_EXPIRES_IN=7d

# Session Configuration
SESSION_SECRET=your_session_secret_here

# LLM Keys
OPENAI_API_KEY=your_openai_api_key
ANTHROPIC_API_KEY=your_anthropic_api_key
GEMINI_API_KEY=your_gemini_api_key

# External Cloud Colab URL for Free 98% Accuracy Whisper Transcription (Optional)
# Set this to the exact Localtunnel URL generated by Google Colab (e.g. https://xxxxxx.loca.lt)
# If blank, the Node.js server will fallback to running local Xenova/Whisper
COLAB_WHISPER_URL=_here

# OAuth Configuration
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
MICROSOFT_CLIENT_ID=your_microsoft_client_id
MICROSOFT_CLIENT_SECRET=your_microsoft_client_secret

# File Upload Configuration
UPLOAD_DIR=uploads
MAX_FILE_SIZE=10485760

# Rate Limiting Configuration
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Logging Configuration
LOG_LEVEL=info
LOG_DIR=logs

# Email Notification Configuration (Optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM=noreply@meetbuddy.ai
ADMIN_EMAIL=admin@meetbuddy.ai
SECURITY_EMAIL=security@meetbuddy.ai

# Webhook Notification Configuration (Optional)
WEBHOOK_URL=https://your-monitoring-system.com/webhook
WEBHOOK_AUTH_HEADER=Bearer your_webhook_token

# Slack Notification Configuration (Optional)
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/SLACK/WEBHOOK
SLACK_CHANNEL=#alerts