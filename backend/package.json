  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/fluent-ffmpeg": "^2.1.28",
    "@types/form-data": "^2.2.1",
    "@types/joi": "^17.2.3",
    "@types/jsonwebtoken": "^9.0.5",
